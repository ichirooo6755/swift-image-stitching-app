{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:ios": "xcodegen generate --spec ios/GigaPanSwift/project.yml && xcodebuild -project ios/GigaPanSwift/GigaPanSwift.xcodeproj -scheme GigaPanSwift -configuration Debug -destination 'generic/platform=iOS' CODE_SIGNING_ALLOWED=NO build",
    "verify:all": "npm run build && npm run build:ios"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
